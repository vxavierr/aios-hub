{
  "language": "portuguese",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash D:/workspace/.claude/commands/AIOS/sync-squad-agents.sh"
          }
        ]
      }
    ]
  }
}
